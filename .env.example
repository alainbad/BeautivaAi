# Copy to .env and fill in real values. Never commit .env.
# VITE_-prefixed vars are bundled into the client — keep only public values there.

# --- Supabase (Settings > API in the Supabase dashboard) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Server-only — bypasses RLS. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (Claude vision skin analysis + AI Beauty Chat) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Stripe (kept in the codebase but currently unused — Premium billing
# runs through Apple In-App Purchase below. Only needed if you later add a
# web checkout path.) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_ID_PREMIUM_YEARLY=price_...

# --- Apple In-App Purchase (active Premium billing path) ---
# See README.md "Apple In-App Purchases" section for how to obtain each value.
APPLE_IAP_ISSUER_ID=your-issuer-id
APPLE_IAP_KEY_ID=your-key-id
# Contents of the .p8 in-app-purchase key from App Store Connect. Paste with
# literal \n for newlines if your .env format requires a single line.
APPLE_IAP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_IAP_BUNDLE_ID=com.beautivaai.app
# Numeric App Store app ID (Apple ID) — required in Production, omit for Sandbox testing.
APPLE_IAP_APP_APPLE_ID=
# "Sandbox" while testing via Xcode/TestFlight, "Production" once live.
APPLE_IAP_ENVIRONMENT=Sandbox
# Base64-encoded DER root certificate(s) from https://www.apple.com/certificateauthority/,
# comma-separated if more than one. Never commit the decoded .cer file.
APPLE_IAP_ROOT_CERTS_BASE64=

# --- App ---
# Public URL of the deployed app. Used for Stripe Checkout success/cancel
# redirects on web, and by capacitor.config.ts (as CAPACITOR_SERVER_URL) to
# point the iOS shell at your deployed backend.
APP_URL=http://localhost:3000
